# Laravel catalog API (server-side fetches)
API_BASE_URL=http://localhost:8000/api/v1
# Public values (browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:8000
# Public site origin — used as the OG/canonical metadataBase and in the WhatsApp
# inquiry/product links. MUST be the real production origin (e.g. https://furnib.com)
# at BUILD time, or social previews and share links point at localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Default WhatsApp number (digits only, intl format). Wired to admin settings later.
NEXT_PUBLIC_WHATSAPP=8801712345678
